# --- Server-side secrets ($env/static/private) ---
# Google Calendar service account (read-only) — powers Shows
MISSY_CALENDAR_CLIENT_EMAIL=service-account@your-project.iam.gserviceaccount.com
MISSY_CALENDAR_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Cloudflare Turnstile secret (server-side validation of the contact form)
# Local dev test key that always passes: 1x0000000000000000000000000000000AA
MISSY_TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# --- Client-side (import.meta.env, VITE_ prefix is public) ---
# Cloudflare Turnstile site key. Local always-pass test key: 1x00000000000000000000AA
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# EmailJS (client-side send of the contact message) — replaced by Resend in Phase 2
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# --- Phase 2 (Stripe shop) — not used yet ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PUBLIC_STRIPE_PUBLISHABLE_KEY=
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=
# ORDER_NOTIFY_EMAIL=
